{
    "permissions": {
        "allow": [],
        "deny": [],
        "defaultMode": "acceptEdits"
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python \"~/.claude/scripts/autocommit_design_docs.py\"",
                        "timeout": 30
                    }
                ]
            },
            {
                "matcher": "Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python \"~/.claude/scripts/autocommit_design_docs.py\"",
                        "timeout": 30
                    }
                ]
            },
            {
                "matcher": "Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python \"~/.claude/scripts/auto_sync_context_hook.py\"",
                        "timeout": 10
                    }
                ]
            },
            {
                "matcher": "Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python \"~/.claude/scripts/auto_sync_context_hook.py\"",
                        "timeout": 10
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python \"~/.claude/scripts/plan_keyword_detector.py\"",
                        "timeout": 15
                    }
                ]
            }
        ]
    }
}
